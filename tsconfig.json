{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",

    "types": ["node"],

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // tsup's declaration build injects a legacy `baseUrl`; silence the
    // deprecation so `.d.ts` emit keeps working on TypeScript 6.x.
    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "test", "tsup.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", "coverage", "test/fixtures"]
}
